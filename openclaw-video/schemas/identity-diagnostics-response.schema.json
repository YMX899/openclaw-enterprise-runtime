{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huahuoai.local/schemas/openclaw-video/identity-diagnostics-response.schema.json",
  "type": "object",
  "required": [
    "authenticated",
    "login_material_present",
    "openclaw_session_present",
    "auth_mode",
    "huahuo_access_token_present",
    "huahuo_app_uuid_present",
    "profile_ok",
    "workspace_ok",
    "access_ok",
    "current_workspace_count",
    "principal_id",
    "failure_stage",
    "provider_probe"
  ],
  "additionalProperties": false,
  "properties": {
    "authenticated": {"type": "boolean"},
    "login_material_present": {"type": "boolean"},
    "openclaw_session_present": {"type": "boolean"},
    "auth_mode": {
      "oneOf": [
        {"enum": ["openclaw_session", "test_identity_headers", "dify", "huahuo_front"]},
        {"type": "null"}
      ]
    },
    "huahuo_access_token_present": {"type": "boolean"},
    "huahuo_app_uuid_present": {"type": "boolean"},
    "profile_ok": {"type": "boolean"},
    "workspace_ok": {"type": "boolean"},
    "access_ok": {"type": "boolean"},
    "current_workspace_count": {"type": "integer", "minimum": 0},
    "principal_id": {
      "oneOf": [
        {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        {"type": "null"}
      ]
    },
    "failure_stage": {
      "oneOf": [
        {"enum": ["profile", "workspace", "access"]},
        {"type": "null"}
      ]
    },
    "provider_probe": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "provider",
            "identity_headers_present",
            "profile_http_status",
            "profile_business_status",
            "profile_data_keys",
            "refresh_attempted",
            "refresh_http_status",
            "refresh_business_status",
            "refresh_issued_access_token",
            "retry_http_status",
            "retry_business_status",
            "retry_data_keys",
            "error_stage"
          ],
          "properties": {
            "provider": {"type": "string"},
            "identity_headers_present": {"type": "boolean"},
            "profile_http_status": {
              "oneOf": [{"type": "integer"}, {"type": "null"}]
            },
            "profile_business_status": {
              "oneOf": [{"type": "integer"}, {"type": "string"}, {"type": "null"}]
            },
            "profile_data_keys": {
              "type": "array",
              "items": {"type": "string"}
            },
            "refresh_attempted": {"type": "boolean"},
            "refresh_http_status": {
              "oneOf": [{"type": "integer"}, {"type": "null"}]
            },
            "refresh_business_status": {
              "oneOf": [{"type": "integer"}, {"type": "string"}, {"type": "null"}]
            },
            "refresh_issued_access_token": {"type": "boolean"},
            "retry_http_status": {
              "oneOf": [{"type": "integer"}, {"type": "null"}]
            },
            "retry_business_status": {
              "oneOf": [{"type": "integer"}, {"type": "string"}, {"type": "null"}]
            },
            "retry_data_keys": {
              "type": "array",
              "items": {"type": "string"}
            },
            "error_stage": {
              "oneOf": [
                {"enum": ["refresh_missing", "refresh_http", "refresh_payload", "retry_http", "network", "json", "probe"]},
                {"type": "null"}
              ]
            }
          }
        },
        {"type": "null"}
      ]
    }
  }
}

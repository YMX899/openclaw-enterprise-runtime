{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huahuoai.local/schemas/openclaw-video/job-event.schema.json",
  "type": "object",
  "required": ["event", "data"],
  "additionalProperties": false,
  "properties": {
    "event": {
      "enum": ["job", "heartbeat", "done", "error"]
    },
    "data": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"event": {"const": "job"}}
      },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["job"],
            "additionalProperties": false,
            "properties": {
              "job": {"$ref": "https://huahuoai.local/schemas/openclaw-video/video-job.schema.json"}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"event": {"const": "heartbeat"}}
      },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["job_id", "status"],
            "additionalProperties": false,
            "properties": {
              "job_id": {"type": "string", "format": "uuid"},
              "status": {
                "enum": ["queued", "running", "succeeded", "failed", "timed_out", "cancelled"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"event": {"const": "done"}}
      },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["job_id", "status"],
            "additionalProperties": false,
            "properties": {
              "job_id": {"type": "string", "format": "uuid"},
              "status": {
                "enum": ["succeeded", "failed", "timed_out", "cancelled"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"event": {"const": "error"}}
      },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["error"],
            "additionalProperties": false,
            "properties": {
              "error": {"type": "string"}
            }
          }
        }
      }
    }
  ]
}
